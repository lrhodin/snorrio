#!/usr/bin/env bash
# snorrio pre-commit: typecheck staged TypeScript.
#
# Activated by `npm run install-hooks` (sets core.hooksPath = .githooks).
# Skip with `git commit --no-verify` when you genuinely need to.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Only run when staged changes touch TypeScript under our typechecked paths.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E '^(src|extensions|skills)/.*\.ts$' || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

if [ ! -x "node_modules/.bin/tsc" ]; then
  echo "pre-commit: typescript not installed locally — run \`npm install\` once."
  echo "pre-commit: skipping typecheck for this commit."
  exit 0
fi

echo "pre-commit: tsc --noEmit on snorrio…"
if ! ./node_modules/.bin/tsc -p tsconfig.json; then
  echo ""
  echo "pre-commit: typecheck failed. Fix the errors above, or commit with --no-verify."
  exit 1
fi
