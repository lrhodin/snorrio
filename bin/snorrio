#!/usr/bin/env node
// snorrio CLI — administrative commands for snorrio.
//
// Usage:
//   snorrio flush                    Flush pending sessions through the daemon
//   snorrio sweep                    Find & generate missing episodes, cascade caches
//   snorrio reprocess <range> [depth] Regenerate from scratch in range
//   snorrio status                   Show daemon and system status
//   snorrio update                   Pull latest and restart daemon

import { existsSync, statSync, writeFileSync, openSync, readSync, closeSync } from "fs";
import { join, dirname } from "path";
import { fileURLToPath } from "url";
import { execSync, execFileSync } from "child_process";

const HOME = process.env.HOME;
const PKG_ROOT = join(dirname(fileURLToPath(import.meta.url)), "..");
const SNORRIO_HOME = process.env.SNORRIO_HOME || join(HOME, "snorrio");
const CONFIG_PATH = join(SNORRIO_HOME, "config", "config.json");
const LOG_DIR = join(SNORRIO_HOME, "logs");
const FLUSH_TRIGGER = join(SNORRIO_HOME, "flush");
const PLIST_PATH = join(HOME, "Library", "LaunchAgents", "io.snorrio.dmn.plist");

const cmd = process.argv[2];

function daemonLoaded() {
  try {
    execFileSync("launchctl", ["list", "io.snorrio.dmn"], { stdio: "pipe" });
    return true;
  } catch {
    return false;
  }
}

async function restartDaemon() {
  const uid = execSync("id -u", { encoding: "utf8" }).trim();

  try { execFileSync("launchctl", ["bootout", `gui/${uid}`, PLIST_PATH], { stdio: "pipe" }); } catch {}

  const unloadDeadline = Date.now() + 5000;
  while (daemonLoaded() && Date.now() < unloadDeadline) {
    await new Promise(resolve => setTimeout(resolve, 100));
  }

  let lastErr;
  for (let attempt = 0; attempt < 5; attempt++) {
    try {
      execFileSync("launchctl", ["bootstrap", `gui/${uid}`, PLIST_PATH], { stdio: "inherit" });
      try { execFileSync("launchctl", ["kickstart", "-k", `gui/${uid}/io.snorrio.dmn`], { stdio: "pipe" }); } catch {}
      return;
    } catch (err) {
      lastErr = err;
      await new Promise(resolve => setTimeout(resolve, 250 * (attempt + 1)));
    }
  }

  throw lastErr;
}

if (!cmd || cmd === "help" || cmd === "--help") {
  console.log(`snorrio — memory system for AI agents

Commands:
  flush                         Flush pending sessions through the daemon
  sweep                         Find & generate missing episodes, cascade caches
  reprocess <range> [depth]     Regenerate from scratch in range
  status                        Show daemon and system status
  update                        Pull latest and restart daemon

Reprocess ranges: YYYY-MM-DD | YYYY-Www | YYYY-MM | YYYY-QN | YYYY
Reprocess depths: episode (default) | day | week | month | quarter`);
  process.exit(0);
}

if (cmd === "flush") {
  writeFileSync(FLUSH_TRIGGER, new Date().toISOString());

  const today = new Date().toISOString().slice(0, 10);
  const logFile = join(LOG_DIR, `${today}.log`);

  let logOffset = 0;
  try { logOffset = statSync(logFile).size; } catch {}

  const SPINNER = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"];
  const CLR = "\x1b[K"; // erase from cursor to end of line, so a shorter frame can't leave tail chars
  let spinIdx = 0;
  const started = Date.now();

  let total = 0;
  let episodesDone = 0;
  let phase = "waiting";

  const poll = setInterval(() => {
    spinIdx = (spinIdx + 1) % SPINNER.length;
    const s = SPINNER[spinIdx];

    if (Date.now() - started > 300_000) {
      console.log("\nFlush timed out (5m)");
      process.exit(1);
    }

    let stat;
    try { stat = statSync(logFile); } catch { return; }
    if (stat.size <= logOffset) {
      const shown = total ? Math.min(episodesDone, total) : episodesDone;
      process.stdout.write(`\r${s} ${phase === "waiting" ? "Waiting for daemon..." : `Episodes: ${shown}/${total}`}${CLR}`);
      return;
    }

    const fd = openSync(logFile, "r");
    const buf = Buffer.alloc(stat.size - logOffset);
    readSync(fd, buf, 0, buf.length, logOffset);
    closeSync(fd);
    logOffset = stat.size;

    const text = buf.toString("utf8");

    if (text.includes("Flush: 0 sessions to process")) {
      console.log(`\r✓ All sessions up to date${CLR}`);
      clearInterval(poll);
      process.exit(0);
    }

    const pendingMatch = text.match(/Flush: (\d+) pending/);
    if (pendingMatch) {
      total = Number(pendingMatch[1]);
      phase = "episodes";
    }

    // NOTE: `Done:` is logged by every episode-generation path (live debounce
    // watcher, flush, sweep). A concurrent live-mode generation during the
    // flush window can emit extra `Done:` lines that aren't part of this batch,
    // so this is an upper bound — clamped to `total` at display time. The
    // authoritative count is the `Flush: N processed` summary line below.
    const doneMatches = text.match(/  Done: /g);
    if (doneMatches) episodesDone += doneMatches.length;

    const summary = text.match(/Flush: (\d+) processed, (\d+) failed/);
    if (summary) {
      const processed = Number(summary[1]);
      const failed = Number(summary[2]);
      let msg = `\r✓ ${processed} episode${processed !== 1 ? "s" : ""}`;
      if (failed > 0) msg += ` (${failed} failed)`;
      msg += " — caches updating in background";
      console.log(msg + CLR);
      clearInterval(poll);
      process.exit(failed > 0 ? 1 : 0);
    }

    const shown = total ? Math.min(episodesDone, total) : episodesDone;
    process.stdout.write(`\r${s} Episodes: ${shown}/${total}${CLR}`);
  }, 200);

} else if (cmd === "sweep") {
  console.log("Running sweep...");
  try {
    execSync(`node ${join(PKG_ROOT, "src/episode-daemon.ts")} --sweep`, {
      stdio: "inherit",
      env: { ...process.env, SNORRIO_HOME },
    });
  } catch (err) {
    process.exit(1);
  }

} else if (cmd === "reprocess") {
  const range = process.argv[3];
  const depth = process.argv[4];
  if (!range) {
    console.error("Usage: snorrio reprocess <range> [depth]");
    console.error("  range: YYYY-MM-DD | YYYY-Www | YYYY-MM | YYYY-QN | YYYY");
    console.error("  depth: episode (default) | day | week | month | quarter");
    process.exit(1);
  }
  const args = [`--reprocess`, range];
  if (depth) args.push(depth);
  try {
    execSync(`node ${join(PKG_ROOT, "src/episode-daemon.ts")} ${args.join(" ")}`, {
      stdio: "inherit",
      env: { ...process.env, SNORRIO_HOME },
    });
  } catch (err) {
    process.exit(1);
  }

} else if (cmd === "status") {
  // Daemon
  let daemonPid = null;
  try {
    const out = execSync("launchctl list io.snorrio.dmn 2>/dev/null", { encoding: "utf8" });
    const pidMatch = out.match(/"PID"\s*=\s*(\d+)/);
    daemonPid = pidMatch ? pidMatch[1] : null;
  } catch {}
  console.log(`Daemon:    ${daemonPid ? `running (PID ${daemonPid})` : "not running"}`);

  // Data home
  console.log(`Data home: ${SNORRIO_HOME}`);

  // Episodes
  const episodesDir = join(SNORRIO_HOME, "episodes");
  const today = new Date().toISOString().slice(0, 10);
  let todayCount = 0;
  let totalDays = 0;
  try {
    const { readdirSync } = await import("fs");
    const days = readdirSync(episodesDir);
    totalDays = days.length;
    const todayDir = join(episodesDir, today);
    if (existsSync(todayDir)) {
      todayCount = readdirSync(todayDir).filter(f => f.endsWith(".md")).length;
    }
  } catch {}
  console.log(`Episodes:  ${todayCount} today, ${totalDays} days total`);

  // Config
  console.log(`Config:    ${existsSync(CONFIG_PATH) ? CONFIG_PATH : "missing"}`);

  // Git status
  try {
    const branch = execSync("git rev-parse --abbrev-ref HEAD", { cwd: PKG_ROOT, encoding: "utf8" }).trim();
    const hash = execSync("git rev-parse --short HEAD", { cwd: PKG_ROOT, encoding: "utf8" }).trim();
    console.log(`Version:   ${branch}@${hash}`);
  } catch {}

} else if (cmd === "update") {
  try {
    console.log("Pulling latest...");
    execSync("git pull --ff-only", { cwd: PKG_ROOT, stdio: "inherit" });

    console.log("Restarting daemon...");
    await restartDaemon();

    console.log("✓ Updated and restarted");
  } catch (err) {
    console.error(`Update failed: ${err.message}`);
    process.exit(1);
  }

} else {
  console.error(`Unknown command: ${cmd}\nRun 'snorrio help' for usage.`);
  process.exit(1);
}
